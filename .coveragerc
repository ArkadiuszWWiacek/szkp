[run]
omit =
    */migrations/*
    */tests/*
    */test_*
    */Functional_tests/*
    manage.py
    */__init__.py
    */settings/*
    */wsgi.py
    */asgi.py

[report]
omit =
    */migrations/*
    */tests/*
    */test_*
    */Functional_tests/*
    manage.py
    */__init__.py
    */settings/*
    */wsgi.py
    */asgi.py